# ================================================================
# ✅ WHAT TO KEEP (Explicit includes)
# ================================================================

# Keep these directories but ignore contents
data/raw/.gitkeep
data/processed/.gitkeep
data/processed/climate/.gitkeep
data/processed/economy/.gitkeep
data/processed/geopolitics/.gitkeep
data/processed/infrastructure/.gitkeep
data/processed/migration/.gitkeep
data/processed/social/.gitkeep
data/processed/trade/.gitkeep

models/trained/.gitkeep
models/checkpoints/.gitkeep
models/evaluation/.gitkeep

pipeline/logs/.gitkeep

# Keep README files in data folders
!data/**/README.md

# ================================================================
# 🎯 SPECIAL EXCEPTIONS
# ================================================================

# Allow specific config files
!.vscode/settings.json
!.vscode/extensions.json

# Allow sample data files
!data/sample*.csv
!data/example*.csv

# Allow small lookup tables (< 1MB)
!data/lookup*.csv
!data/metadata*.csv
