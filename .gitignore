# ================================================================
# 🤖 MACHINE LEARNING & MODELS
# ================================================================

# Trained models - KEEP SMALL MODELS, IGNORE LARGE CHECKPOINTS
# For deployment, commit essential models (< 50MB)
!models/trained/*.pkl
!models/trained/*.joblib

# Ignore large/deep learning models
models/trained/*.h5
models/trained/*.pth
models/trained/*.pt
models/trained/*.keras

# Model checkpoints (always ignore)
models/checkpoints/
models/evaluation/*.csv

# Model weights and parameters
*.weights
*.params

# TensorBoard logs
logs/
events.out.tfevents*

# MLflow
mlruns/
.mlflow/

# ================================================================
# 📊 DATA FILES
# ================================================================

# Raw data (never commit - too large)
data/raw/*
!data/raw/.gitkeep

# Large processed files (regeneratable, don't commit)
data/processed/climate/climate_features.csv
data/processed/climate/final_climate.csv
data/processed/trade/cleaned_trade.csv
data/processed/trade/final_trade.csv
data/processed/trade/trade_features.csv

# Intermediate processing files
data/external/
data/intermediate/

# Essential small processed/output files (COMMIT THESE - needed for API)
!data/processed/climate/climate_risk_district.csv
!data/processed/climate/climate_risk_state.csv
!data/processed/climate/climate_risk_output.csv
!data/processed/trade/trade_features_clean.csv
!data/processed/trade/trade_risk_country.csv
!data/processed/trade/trade_risk_output.csv
!data/processed/trade/trade_risk_top.csv
!data/processed/interconnection/global_risk.csv
!data/processed/interconnection/interconnected_risk.csv

# Keep dataset summary
!data/processed/dataset_summary.csv

# Large datasets
*.parquet
*.feather
*.h5
*.hdf5

# Keep only small sample files if needed
!data/sample_*.csv

